{
  "data_asset_type": null,
  "expectation_suite_name": "bronze_cdc_orders",
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "notes": {
      "format": "markdown",
      "content": [
        "Bronze — raw.cdc_orders. Debezium CDC stream. Validate op codes, timestamps, and envelope structure."
      ]
    }
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": null
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "cdc_id",
          "op",
          "ts_ms",
          "source_db",
          "source_table",
          "txn_id",
          "before",
          "after",
          "ingested_at"
        ]
      },
      "meta": {
        "notes": "Schema guard — Debezium envelope columns must be stable."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "cdc_id"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {
        "column": "cdc_id"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "cdc_id",
        "regex": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "op"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "op",
        "value_set": [
          "c",
          "u",
          "d",
          "r"
        ]
      },
      "meta": {
        "notes": "c=create, u=update, d=delete, r=snapshot read. Any other value is a Debezium bug."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "ts_ms"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "ts_ms",
        "min_value": 1000000000000,
        "max_value": null
      },
      "meta": {
        "notes": "Epoch ms > 2001-09-09 (sanity check against epoch=0 bugs)."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "source_db"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "source_table"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "after",
        "mostly": 0.9
      },
      "meta": {
        "notes": "after is null only for deletes (op=d), a small fraction of CDC traffic. A row_condition (op in c/u/r) would be exact, but GX 0.18 row conditions poison the bundled Trino metrics query and fail the whole suite."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "ingested_at"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
      "kwargs": {
        "column": "cdc_id",
        "min_value": 1.0,
        "max_value": 1.0
      },
      "meta": {
        "notes": "Every row must have a unique ingestion ID."
      }
    }
  ]
}
