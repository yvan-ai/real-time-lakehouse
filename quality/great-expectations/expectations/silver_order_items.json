{
  "data_asset_type": null,
  "expectation_suite_name": "silver_order_items",
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "notes": "Silver — silver.order_items. Line items parsed from CDC JSON. Validate FK integrity markers, positive quantities/prices, and line_total arithmetic. Columns aligned with data/models/iceberg/silver/order_items.sql (July 2026 trim: product_name/category/discount/currency dropped)."
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 1, "max_value": null},
      "meta": {}
    },
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "item_id", "order_id", "product_id", "quantity",
          "unit_price", "line_total", "order_created_at", "_ingested_at"
        ]
      },
      "meta": {"notes": "Schema guard — must match the Silver DDL exactly."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "item_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "item_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "product_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "quantity"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "quantity",
        "min_value": 1,
        "max_value": 10000
      },
      "meta": {"notes": "Quantity must be >= 1. Upper bound 10 000 flags data entry errors."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "unit_price"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "unit_price",
        "min_value": 0.0,
        "max_value": null,
        "mostly": 0.999
      },
      "meta": {"notes": "Free items (price=0) are valid but rare; negative prices are not."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "line_total"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "line_total",
        "min_value": 0.0,
        "max_value": null,
        "mostly": 0.999
      },
      "meta": {"notes": "line_total = quantity * unit_price, so it inherits their sign."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_created_at", "mostly": 0.99},
      "meta": {"notes": "Enriched via left join with silver.orders — null only when the parent order is missing from Silver."}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "_ingested_at"},
      "meta": {}
    }
  ]
}
