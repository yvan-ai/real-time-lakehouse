# Shared yamllint config — used by CI, pre-commit, Makefile and scripts/test.sh
extends: default

rules:
  line-length:
    max: 160
  indentation:
    # `kustomize edit set image` (run by the CD workflow) rewrites
    # kustomization.yaml with non-indented sequences — accept both styles.
    indent-sequences: whatever
  comments-indentation: disable
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false          # allow the `on:` key in GitHub workflows
  comments:
    min-spaces-from-content: 1
  document-start: disable      # Kubernetes manifests conventionally omit `---`

ignore: |
  infra/kubernetes/base/monitoring/grafana.yaml
  .claude/
  # Terraform provider/module caches (created by `terraform init`)
  **/.terraform/
