{
  "uid": "pipeline-lakehouse",
  "title": "Lakehouse Pipeline",
  "tags": ["pipeline", "lakehouse", "business"],
  "schemaVersion": 36,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Debezium Connector (running tasks)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(kafka_connect_connector_task_status{connector=\"debezium-postgres\", status=\"running\"}) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Replication Slot Lag",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "max(pg_replication_slots_lag_bytes{slot_type=\"logical\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 67108864, "color": "yellow"},
              {"value": 268435456, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Quality Gate (last run)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "min(gx_quality_gate_success)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "FAILED", "color": "red"},
                "1": {"text": "PASSED", "color": "green"}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Time Since Last Successful Batch",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "time() - max(kube_job_status_completion_time{namespace=\"spark\", job_name=~\"batch-pipeline.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 86400, "color": "yellow"},
              {"value": 259200, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CDC Throughput per Topic (messages/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset{topic=~\"debezium.public.*\"}[5m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "mps", "color": {"mode": "palette-classic"}}},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Consumer Lag by Group / Topic",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}} / {{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Windows Emitted per Minute (gold.order-revenue-1m)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"gold.order-revenue-1m\"}[5m])) * 60",
          "legendFormat": "windows/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Flink Checkpoints — Duration & Failures",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "flink_jobmanager_job_lastCheckpointDuration",
          "legendFormat": "duration (ms) — {{job_name}}",
          "refId": "A"
        },
        {
          "expr": "increase(flink_jobmanager_job_numberOfFailedCheckpoints[10m])",
          "legendFormat": "failed (10m) — {{job_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Replication Slot Lag Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "pg_replication_slots_lag_bytes",
          "legendFormat": "{{slot_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "decbytes", "color": {"mode": "palette-classic"}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Quality Gate — Failed Expectations by Layer",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "gx_expectations_failed",
          "legendFormat": "{{layer}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
    }
  ]
}
