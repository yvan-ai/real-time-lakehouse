# Secrets — never commit actual credentials
infra/kubernetes/overlays/*/minio.env
infra/kubernetes/overlays/*/secrets.env
*.env
!*.env.example

# Terraform state and local overrides
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# Python
__pycache__/
*.py[cod]
.venv/
dist/
*.egg-info/

# Java / Scala build artifacts
target/
*.jar
*.class

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Claude Code local permissions & machine-specific launch config
.claude/settings.local.json
.claude/launch.json

# Local tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# Kubeconfig overrides (keep default at ~/.kube/config)
kubeconfig
kubeconfig.yaml

# Great Expectations — runtime artefacts (validation results, data docs, profilers)
quality/great-expectations/uncommitted/validations/
quality/great-expectations/uncommitted/data_docs/
quality/great-expectations/uncommitted/profilers/

# dbt local artifacts (runs from pipelines/dbt)
pipelines/dbt/.user.yml
pipelines/dbt/logs/
pipelines/dbt/dbt_packages/
