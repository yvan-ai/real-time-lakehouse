# Airflow credentials template — copy to airflow.env (gitignored) and edit,
# or let ./scripts/bootstrap.sh generate one with random values.
#
# AIRFLOW_FERNET_KEY must be 32 url-safe base64-encoded bytes, e.g.:
#   head -c 32 /dev/urandom | base64 | tr '+/' '-_'
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me
AIRFLOW_ADMIN_PASSWORD=change-me
AIRFLOW_WEBSERVER_SECRET_KEY=change-me
AIRFLOW_FERNET_KEY=change-me
